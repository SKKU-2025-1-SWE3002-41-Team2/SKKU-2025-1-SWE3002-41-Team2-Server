# .env 파일
# 데이터베이스 연결 URL (FastAPI에서 사용) - root 사용자로 변경
DATABASE_URL="mysql+pymysql://root:root_pass@localhost:3307/excel_platform_db"

# 데이터베이스 설정 (개별 변수로도 관리 - 선택사항)
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=root_pass
DB_NAME=excel_platform_db

# MySQL 루트 비밀번호 (관리용)
DB_ROOT_PASSWORD=root_pass


SECRET_KEY=your_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=30
LLM_API_KEY=dummy_for_now
